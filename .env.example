# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# ── Recommended ───────────────────────────────────────────────────────────────
# Tavily API key for web search (get one free at https://tavily.com)
TAVILY_API_KEY=tvly-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Your Discord server/guild ID — enables instant slash command sync (vs. up to 1 hour globally)
# Right-click your server icon → Copy Server ID (requires Developer Mode in Discord settings)
DISCORD_GUILD_ID=

# Only needed if llm.provider = "openai" in config.yaml
OPENAI_API_KEY=sk-...
